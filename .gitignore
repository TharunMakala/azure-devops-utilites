# Azure DevOps Utilities - .gitignore

# Credentials and secrets
*.env
.env.*
secrets/
credentials/
*.pfx
*.pem
*.key
*.p12

# Azure CLI and config
.azure/
azure.json
azureProfile.json

# PowerShell
*.ps1xml
!*.format.ps1xml
!*.types.ps1xml

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
env/
.Python
pip-log.txt
pip-delete-this-directory.txt

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE and editor files
.vscode/settings.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Terraform
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Go
tools/pipeline-monitor/pipeline-monitor
tools/pipeline-monitor/go.sum

# Build outputs
bin/
obj/
out/
*.log
*.tmp

# Test results
TestResults/
coverage/
*.coverage
*.coveragexml

# Package files
*.zip
*.tar.gz
*.nupkg

# Local override files
*.local.*
local/

# Dashboard output
dashboard.html
*.sarif

# Helm
helm/**/charts/
helm/**/*.tgz

# k6
k6-results.json
